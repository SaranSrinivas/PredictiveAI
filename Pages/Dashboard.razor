@page "/ai-dashboard"
@using System.Text.Json
@inject PredictiveAnalysis.Services.PredictiveAnalysisService AnalysisService

<h3>Dashboard</h3>

<button class="btn btn-primary" @onclick="Refresh" disabled="@isLoading">Refresh</button>

<LoadingSpinner Visible="@isLoading" Message="@loadingMessage" />

@if (summary is not null && !isLoading)
{
    <div class="mt-3">
        <pre>@JsonSerializer.Serialize(summary, new JsonSerializerOptions { WriteIndented = true })</pre>
        <!-- Add additional dashboard UI here -->
    </div>
}

@code {
    private bool isLoading;
    private PredictiveAnalysis.Models.DashboardSummary? summary;

    // Meaningful loading messages to cycle through while AnalyzeAsync runs
    private readonly string[] loadingSteps = new[]
    {
        "Loading seed data...",
        "Building feature sets...",
        "Enriching parts data...",
        "Evaluating business rules...",
        "Running ML model...",
        "Finalizing results..."
    };

    private string loadingMessage = "Loading...";
    private CancellationTokenSource? _loadingCts;

    protected override async Task OnInitializedAsync()
    {
        await StartAndLoadAsync();
    }

    private async Task StartAndLoadAsync()
    {
        isLoading = true;
        // Start cycling messages
        _loadingCts = new CancellationTokenSource();
        _ = Task.Run(() => CycleLoadingMessages(_loadingCts.Token));

        await Refresh();
    }

    private async Task CycleLoadingMessages(CancellationToken token)
    {
        var i = 0;
        try
        {
            while (!token.IsCancellationRequested)
            {
                loadingMessage = loadingSteps[i % loadingSteps.Length];
                i++;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(650, token);
            }
        }
        catch (TaskCanceledException) { }
    }

    private async Task Refresh()
    {
        // Ensure UI has a chance to render the first message
        await InvokeAsync(StateHasChanged);

        try
        {
            summary = await AnalysisService.AnalyzeAsync();
        }
        catch (Exception)
        {
            // handle/log if desired
        }
        finally
        {
            // Stop cycling messages
            _loadingCts?.Cancel();
            _loadingCts?.Dispose();
            _loadingCts = null;

            isLoading = false;
            loadingMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }
}